rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email in ['cariavata1@gmail.com']; }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stats/{dateId} {
      allow read: if isAdmin();
      // Visitors tracking logic: any app instance can increment stats.
      // But they'll just set fields. Since we can't secure tracking easily without functions,
      // I'll allow anyone to write to stats, but maybe just `update`? 
      // Firestore rules for anonymous writes matching the structure:
      allow create, update: if true; 
    }
  }
}

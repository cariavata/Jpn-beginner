rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'cariavata1@gmail.com'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidAppData(data) {
      return data.keys().hasAll(['siteTitle']) && data.keys().size() >= 1;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(settingId) && isValidAppData(incoming());
      allow update: if isAdmin() && isValidAppData(incoming());
    }

    function isValidAppStats(data) {
      return data.keys().hasAll(['visitors']);
    }

    match /stats/{dateId} {
      allow read: if isAdmin();
      allow create: if isValidId(dateId) && isValidAppStats(incoming());
      allow update: if isValidAppStats(incoming());
    }
  }
}
